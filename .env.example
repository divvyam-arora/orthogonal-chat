DATABASE_URL=postgresql://user:password@host.neon.tech/orthogonal_chat?sslmode=require

# NextAuth (Auth.js v5) — see README §2 for GitHub OAuth setup
AUTH_SECRET=replace_with_32_plus_char_random_string_aaaaaaaa
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# On Vercel set AUTH_TRUST_HOST=true so the callback URL is detected behind the proxy
AUTH_TRUST_HOST=

ANTHROPIC_API_KEY=sk-ant-...
ORTHOGONAL_API_KEY=
ORTHOGONAL_API_BASE_URL=https://api.orthogonal.dev
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BUDGET_USD_PER_SESSION=10
DEFAULT_MODEL=claude-sonnet-4-5
SUMMARY_MODEL=claude-haiku-4-5
CONTEXT_TOKENS_PER_CONVERSATION=24000
ORTHOGONAL_CACHE_TTL_SEC=60
ORTHOGONAL_CIRCUIT_FAILURES=3
ORTHOGONAL_CIRCUIT_OPEN_SEC=60
ORTHOGONAL_FAKE=false
